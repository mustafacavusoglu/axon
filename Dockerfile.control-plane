FROM golang:1.22-alpine AS builder

WORKDIR /build

COPY control-plane/go.mod control-plane/go.sum ./
RUN go mod download

COPY control-plane/ ./
COPY proto/ ../proto/

RUN CGO_ENABLED=0 go build -o /control-plane ./cmd/server

FROM alpine:3.21

RUN apk add --no-cache ca-certificates

COPY --from=builder /control-plane /usr/local/bin/control-plane

EXPOSE 8080 8001

ENTRYPOINT ["control-plane"]
